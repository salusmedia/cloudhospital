# 院内生产配置样例。复制为 config/.env 并填写真实值。
# ⚠️ 本文件含密钥，绝不进仓库/不进镜像（已在 .gitignore 忽略 config/.env）。

# ---- 镜像坐标（一般由离线包的 .image.env 自动带入，可不填）----
REGISTRY=registry.hospital.local
TAG=v1.0.0

# ---- 对外端口 ----
PUBLIC_PORT=8080

# ---- PostgreSQL（app 用同一组凭据连接）----
POSTGRES_USER=hospital
POSTGRES_PASSWORD=请改为强随机密码
POSTGRES_DB=hospital

# ---- 安全密钥（每院独立，强随机；网关/auth 共享 JWT）----
JWT_SECRET=请改为长随机串
PII_KEY=请改为长随机串

# ---- 生产开关 ----
# 生产必须 false：不灌演示患者数据，只跑 schema 迁移。
SEED_DEMO=false
