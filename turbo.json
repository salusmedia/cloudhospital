{
  "$schema": "https://turbo.build/schema.json",
  "//": "任务编排与增量缓存。只重跑受改动影响的包，CI 因此很快。",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "check": {
      "//": "聚合门禁：lint + typecheck + test",
      "dependsOn": ["lint", "typecheck", "test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
